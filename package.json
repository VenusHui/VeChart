{
  "name": "vechart",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev:web": "npm --workspace @vechart/web run dev",
    "dev:api": "npm --workspace @vechart/api run start:dev",
    "build:web": "npm --workspace @vechart/web run build",
    "build:api": "npm --workspace @vechart/api run build",
    "lint:web": "npm --workspace @vechart/web run lint",
    "lint:api": "npm --workspace @vechart/api run lint",
    "check": "npm run build:api && npm run build:web"
  }
}
